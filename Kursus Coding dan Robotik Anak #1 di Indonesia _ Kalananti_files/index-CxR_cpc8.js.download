desc}</p>\n          </div>\n          <div class="flex items-center justify-center">\n            <img class="h-20" src="${n.icon}" alt="">\n          </div>\n        </div>\n        <div class="grid grid-cols-2 gap-2 font-bold text-center text-[11px]">\n          ${n.poin.map((a=>`\n            <div class="ring-2 ring-[#205084] px-1 py-2 rounded-full flex justify-center items-center">\n              ${a}\n            </div>\n          `)).join("")}\n        </div>\n      </div>\n    `})),$("#program").html(a)}()})),$(document).on("click",".branch-item",(function(){$(".branch-item").removeClass("active"),$(this).addClass("active");let a=$(this).data("maps"),n=""==a||null==a||"null"==a?'<div class="text-center">Sedang dalam proses renovasi<br> Silahkan hubungi kami untuk informasi selanjutnya</div>':`<iframe class="w-full h-full rounded-2xl" src="${a}" frameborder="0"></iframe>`;$(".map-embed").html(n)}));let S=!1;$(document).on("click","#selengkapnya",(function(){S=!S,S?($("#showMore").show(),$("#selengkapnya").html("Sembunyikan!")):($("#showMore").hide(),$("#selengkapnya").html("Selengkapnya!"))})),$(document).on("keyup",".search-branch",(function(a){const n=$(this).val();$(".branch-item").hide(),$(`.branch-item:icontains(${n})`).show()})),$(".prestasi-slick").not(".slick-initialized").slick({lazyLoad:"ondemand",infinite:!0,dots:!0,arrows:!1,autoplay:!1,speed:300,slidesToShow:2,slidesToScroll:1,responsive:[{breakpoint:768,settings:{slidesToShow:1,slidesToScroll:1}}]}),$(".prestasi-slick").slick("slickGoTo",0),$(".customPrevBtnPrestasi").on("click",(function(){$(".prestasi-slick").slick("slickPrev")})),$(".customNextBtnPrestasi").on("click",(function(){$(".prestasi-slick").slick("slickNext")})),$(".testimoni-slick").not(".slick-initialized").slick({lazyLoad:"ondemand",infinite:!0,dots:!0,arrows:!1,autoplay:!1,speed:300,slidesToShow:3,slidesToScroll:1,responsive:[{breakpoint:768,settings:{slidesToShow:1,slidesToScroll:1}}]}),$(".testimoni-slick").slick("slickGoTo",0),$(".customPrevBtn").on("click",(function(){$(".testimoni-slick").slick("slickPrev")})),$(".customNextBtn").on("click",(function(){$(".testimoni-slick").slick("slickNext")})),$(".customPrevBtnExhibition").on("click",(function(){$(".exhibition-slick").slick("slickPrev")})),$(".customNextBtnExhibition").on("click",(function(){$(".exhibition-slick").slick("slickNext")}));const j=[{title:"Independence Day Traditional Games",studentName:"Agatha Christelle Mikaella Aridono",studentPhoto:"https://cdn-web-2.ruangguru.com/landing-pages/assets/a74d13a6-317f-48f8-9bcd-9ee1c11d253a.jpeg?convert=webp",school:"SDK Sang Timur Cakung (II)",program:"ScratchJr",thumbnail:"https://cdn-web-2.ruangguru.com/landing-pages/assets/9eab02cf-64d6-4168-9b43-35ee0c31a334.png?convert=webp",description:"<p>Proyek yang dbuat di ScratchJr untuk merayakan Hari Kemerdekaan Indonesia yang seru dan penuh semangat! Di proyek ini, terdapat berbagai perlombaan tradisional seperti Balap Karung dan Lomba Makan Kerupuk.</p>\n<br>\nKonsep yang digunakan:</p>\n<p><b>Looks</b>: Karakter bisa berubah ekspresi, posisi, dan gerakannya, misalnya saat meloncat dengan karung atau saat makan kerupuk.</p>\n<p><b>Messages</b>: Pesan untuk mengatur giliran pemain dan memulai aksi antar karakter, contohnya saat satu pemain selesai, lalu pemain lain mulai.</p>\n<p><b>Control dan Timer</b>: Blok waktu digunakan untuk memberi jeda, menghitung mundur sebelum lomba dimulai, dan juga mengatur durasi tiap perlombaan.</p>",howToPlay:"<p>1. Tekan bendera hijau untuk memulai animasi</p>\n<p>2. Tekan tombol PLAY untuk memulai permainan. Karakter mulai ikut lomba satu per satu.</p>\n<p>3. Untuk permainan Balap Karung, pemain perlu menekan tombol panah ke atas dalam menggerakkan karakternya.</p>\n<p>4. Sementara itu, untuk Lomba Makan Kerupuk kamu perlu menavigasi pergerakkan mulut karakter menggunakan panah 4 arah.</p>",link:"https://drive.google.com/file/d/1se5DMeOZB2QFDjFiyYXNA-mC5N_rqsQn/view?usp=sharing"},{title:"Zero Hunger",studentName:"Pijar Manggala Shatiladitya",studentPhoto:"https://cdn-web-2.ruangguru.com/landing-pages/assets/54c09862-b867-4061-86d1-84811a72ebdc.jpeg?convert=webp",school:"SD Kreativitas Anak Indonesia (VI)",program:"Scratch",thumbnail:"https://cdn-web-2.ruangguru.com/landing-pages/assets/88a80aac-cad8-45d8-ab33-01eebf9fc10c.png?convert=webp",description:"<p>Permainan ini bercerita tentang menjaga tanaman supaya bisa tumbuh sehat dan dipanen. Pemain harus memilih obat atau “senjata” yang tepat untuk memusnahkan hama. Kalau hama berhasil dikalahkan, tanaman bisa tumbuh subur dan membantu mengatasi masalah kekurangan pangan.</p>\n\n<p>Konsep yang digunakan:</p>\n<p><b>Timer</b>: Waktu berjalan untuk memberi tantangan saat memilih obat.</p>\n<p><b>Event Mouse Click</b>: Pemain mengklik obat yang tepat untuk menyerang hama.</p>\n<p><b>Effects</b>: Efek visual muncul saat hama terkena serangan.</p>\n<p><b>Switch Costume</b>: Tampilan karakter atau hama berubah ketika terkena obat atau saat tanaman sudah sehat.</p>",howToPlay:"<p>1. Klik tombol Start untuk memulai permainan.</p>\n<p>2. Perhatikan hama yang muncul di sekitar tanaman.</p>\n<p>3. Pilih obat atau senjata yang tepat sesuai hama yang ada.</p>\n<p>4. Arahkan mouse ke hama-hama yang muncul, lalu klik dan tahan senjata untuk mengusir hama sebelum waktu habis.</p>\n<p>5. Setiap hama yang dikalahkan membuat tanaman tumbuh lebih sehat.</p>\n\n<p>Kalahkan semua hama agar tanaman bisa dipanen dengan sukses!</p>",link:"https://scratch.mit.edu/projects/1197735757/"},{title:"Dino ROAR!",studentName:"Athariq Alifcakra Malangjoedo",studentPhoto:"https://cdn-web-2.ruangguru.com/landing-pages/assets/0794b7be-47bf-4788-bc8f-9e9674ba8d91.jpeg?convert=webp",school:"Hanifa Islamic School (V)",program:"Scratch",thumbnail:"https://cdn-web-2.ruangguru.com/landing-pages/assets/a6b7d3d4-fdbf-4581-9151-072d3cb81cd0.png?convert=webp",description:"<p>Bersiaplah untuk petualangan lari tanpa akhir bersama Dino dengan cara yang benar-benar baru! Dalam game endless runner yang seru ini, tugasmu adalah membantu Dino bertahan hidup selama mungkin dengan melompati semua rintangan kaktus yang muncul di hadapannya.</p>\n\n<p>Yang membuat game ini unik adalah cara mengontrolnya! Lupakan keyboard, karena untuk membuat Dino melompat, kamu harus menggunakan suaramu. Berteriak atau buat suara keras di dekat mikrofon untuk memerintahkan Dino melompat. Uji refleks dan kekuatan suaramu untuk mencetak rekor tertinggi! Semakin lama kamu bertahan, semakin cepat permainan akan berjalan.</p>\n\n<p>Konsep yang digunakan:</p>\n\n<p>- Sensing (Sound): Pemain mengontrol lompatan Dino sepenuhnya menggunakan sensor loudness > 30. Game ini menangkap suara keras dari mikrofon sebagai satu-satunya pemicu untuk beraksi.</p>\n<p>- Variables (Score and Speed): Permainan menyimpan score pemain dan membandingkannya dengan high score. Selain itu, variabel speed digunakan untuk meningkatkan kecepatan gerakan tanah dan rintangan secara bertahap, membuat game semakin menantang.</p>\n<p>- Control (Cloning): Rintangan kaktus tidak terbatas dan dibuat secara terus-menerus menggunakan blok create clone of myself. Setiap klon bergerak mandiri hingga keluar layar atau menabrak pemain.</p>\n<p>- Events (Broadcast): Sistem siaran (broadcast) PLAY GAME dan STOP GAME digunakan sebagai pemicu utama untuk memulai dan mengakhiri permainan, mengontrol semua sprite (Dino, tanah, rintangan, dan tombol) secara serentak.</p>",howToPlay:"<p>1. Tekan Bendera Hijau untuk menampilkan halaman judul.</p>\n<p>2. Tekan tombol apa saja di keyboard untuk memulai permainan.</p>\nUntuk membuat Dino melompat, berteriak atau bersuara keras ke mikrofon komputermu.</p>\n<p>3. Hindari semua rintangan kaktus dengan melompat di waktu yang tepat menggunakan suaramu.</p>\n<p>4. Teruslah berlari selama mungkin untuk mencetak skor tertinggi. Permainan akan menjadi lebih cepat seiring berjalannya waktu.</p>\n<p>5. Jika Dino menabrak kaktus, permainan akan berakhir. Klik tombol Restart yang muncul untuk mencoba lagi!</p>",link:"https://scratch.mit.edu/projects/1207226424/fullscreen/"},{title:"Real-Time Indonesian Sign Language Interpreter",studentName:"Rajendra Verrill Hafizha",studentPhoto:"https://cdn-web-2.ruangguru.com/landing-pages/assets/bd9b7916-1d6b-4683-8312-c17b00957f8a.jpg?convert=webp",school:"SMA Negeri 2 Kota Tangerang Selatan (XII-8)",program:"Python Programming",thumbnail:"https://cdn-web-2.ruangguru.com/landing-pages/assets/2ff7cc54-daca-482e-96e8-1f6a625201f8.png?convert=webp",description:"<p>Description:</p>\n<p>This project is a real-time sign language recognition system designed to interpret Indonesian Sign Language (SIBI).\nBy capturing live video input from a camera, detects and tracks hand gestures using machine learning (TensorFlow), and classifies the gestures into corresponding sign language letters or words.</p>\n\n<p>Tools Used:</p>\n<p>- Python 3.10</p>\n<p>- PyCharm IDE</p>\n<p>- OpenCV</p>\n<p>- MediaPipe (Hands)</p>\n<p>- TensorFlow / Keras</p>\n<p>- NumPy</p>",howToPlay:"<p>How it Works:</p>\n<p>Uses a camera / webcam to capture video frames and by using MediaPipe Hands, detect the hand landmarks and tracks their position each frame. Then, the detected hand is analyzed by a pretrained Keras model and matches it with the corresponding letter. It then counts the average prediction for the letters, and takes the highest average confidence rate and types it to screen.</p>\n\n<p>Project File:</p>\n<p>Project files are included in this Drive, in there you can see the dataset (training and validation, which I took myself using the same webcam) I used to train the AI. Also a Jupyter Notebook explaining the process of AI learning.</p>",link:"https://drive.google.com/file/d/1-m4WeSD9tyTDxnrnh16DC8xRHFu4VMAg/view?usp=sharing"},{title:"Smart Auto Door System",studentName:"Muhammad Hassan Wirai",studentPhoto:"https://cdn-web-2.ruangguru.com/landing-pages/assets/a6095532-4cab-4943-8a4e-2ef4cc69b700.jpg?convert=webp",school:"SMP Model Ar Riyadh Insan Cendekia (VIII)",program:"Micro:bit",thumbnail:"https://cdn-web-2.ruangguru.com/landing-pages/assets/4f880e34-9931-4d02-b92f-ba5543399d38.png?convert=webp",description:'<p>Smart Auto Door System"" adalah sebuah proyek otomasi sederhana yang menggunakan Yahboom Micro:bit sebagai mikrokontroler utama untuk menciptakan sistem pintu otomatis. Proyek ini memungkinkan pintu terbuka dan tertutup secara otomatis ketika sensor infrared mendeteksi keberadaan objek atau orang di dekat pintu.</p>\n\n<p>Sensor infrared mengirimkan sinyal ke Micro:bit saat ada objek mendekat. Kemudian, Micro:bit mengaktifkan servo motor yang menggerakkan pintu untuk membuka. Setelah objek menjauh atau tidak terdeteksi lagi dalam waktu tertentu, servo motor akan kembali memposisikan pintu ke keadaan tertutup.</p>\n\n<p>Proyek ini meniru sistem otomatisasi pintu modern seperti yang sering digunakan di pusat perbelanjaan, kantor, atau gedung publik.</p>\n\n<p>Konsep yang diajarkan</p>\n<p>Input Sensor (Infrared): Untuk mendeteksi keberadaan objek atau manusia.</p>\n\n<p>Micro:bit Programming: Untuk mengatur logika buka-tutup pintu berdasarkan input dari sensor.</p>\n\n<p>Servo Motor Control: Untuk mengatur mekanisme gerakan pintu.</p>\n\n<p>Conditional Logic (if-else): Untuk mengevaluasi apakah kondisi sensor aktif dan memicu aksi.</p>\n\n<p>Looping dan Delay: Untuk memberikan jeda waktu sebelum pintu tertutup kembali secara otomatis.</p>',howToPlay:'<p>Cara Menjalankan Project ""Smart Auto Door System""\nSiapkan perangkat keras:</p>\n\n<p>Yahboom Micro:bit (beserta power supply jika diperlukan)</p>\n\n<p>Sensor infrared</p>\n\n<p>Servo motor</p>\n\n<p>Kabel jumper dan board penghubung</p>\n\n<p>Rakit komponen sesuai skema:</p>\n\n<p>. Sambungkan sensor infrared ke pin input Micro:bit (misalnya pin P0)</p>\n\n<p>. Sambungkan servo motor ke pin output (misalnya pin P1)</p>\n\n<p>. Pastikan semua komponen terhubung dengan benar dan aman.</p>\n\n<p>. Upload program ke Micro:bit:</p>\n\n<p>. Buka editor MakeCode (https://makecode.microbit.org/)</p>\n\n<p>. Masukkan blok/blok kode atau script Python sesuai logic buka-tutup pintu</p>\n\n<p>. Sambungkan Micro:bit ke komputer dan upload kode</p>\n\n<p>Uji sistem:</p>\n\n<p>. Arahkan tangan atau benda ke depan sensor infrared</p>\n\n<p>. Servo motor akan secara otomatis membuka pintu</p>\n\n<p>. Setelah beberapa detik atau saat objek menjauh, pintu akan tertutup kembali</p>\n\n<p>. Gunakan proyek ini untuk memahami:</p>\n\n<p>. Cara kerja sensor sebagai input sistem</p>\n\n<p>Pengaturan gerakan motor</p>\n\n<p>Penggunaan mikrokontroler dalam sistem otomatisasi sehari-hari</p>',link:"https://drive.google.com/file/d/1JX-lfoMlPNP0oMCe0uJr4pYtAmLrdSyN/view?usp=drive_link"},{title:"The Little Detective Adventures",studentName:"Aryasatya Prayoga",studentPhoto:"https://cdn-web-2.ruangguru.com/landing-pages/assets/e35b84a1-53ab-4ff6-8a07-a133aefa2283.jpeg?convert=webp",school:"SMA Negeri 71 Jakarta (X)",program:"Python Programming",thumbnail:"https://cdn-web-2.ruangguru.com/landing-pages/assets/1e8f439f-9669-4c8b-8930-3f39cbce0e73.png?convert=webp",description:'<p>""Find The Culprit"" adalah sebuah game yg berbasis teks dimana pemain berperan\nsebagai detektif yang ditugaskan untuk memecahkan sebuah misteri didalam rumah. \nPemain diharuskan mencari petunjuk di seluruh area rumah, dengan berinteraksi dengan \nkarakter ( NPC ) atau mencari hint, kalian bisa menebak siapa dalang yang sebenarnya.</p>\n\n<p>game ini mengajarkan konsep logika kondisi, input/output yang interaktif \n( sesuai kondisi yang dipilih pemain )</p>\n\nKonsep:\n<p>pemrograman berorientasi objek (OOP) : berisi kelas / ""class"" character,npc,player,location</p>\n<p>menerima input dari user : game yang mewajibkan user membuat sebuah keputusan</p>\n<p>logika kondisional : mengatur alur berdasarkan keputusan user ( misal pindah ruangan,berbicara, dan menebak )\n<p>desain game berbasis teks dengan narasi interaktif dan secara real-time.</p>',howToPlay:'<p>1. Jalankan program dan masukan nama detektifmu</p>\n<p>2. Kamu memulai investigasi di dalam rumah</p>\n<p>3. telusurilah ke setiap ruangan ruangan yang berada di dalam rumah, dan cari\nhint, serta berinteraksilah dengan orang orang di sekitar ruangan tersebut!!</p>\n<p>4. setelah mendapatkan semua hint, kamu harus memikirkan secara rasional dan logika, siapa pelaku aslinya?</p>\n<p>5. jika sudah yakin dan pasti jawabannya, kamu bisa mengetik ""curiga"" dan menuliskan siapa orang tersebut.</p>\n<p>6. kondisi menang/kalah</p>\n<br/>\n<p>Jika benar, selamat anda detektif sejati. \nJika salah, maaf anda gagal menebak dalangnya.</p>',link:"https://colab.research.google.com/drive/1QhFqd5l-PRpitv_UJxc-Sr5bfY182iap?usp=sharing"},{title:"Good Health and Well-Being",studentName:"Alya Rahmadanisa Putri",studentPhoto:"https://cdn-web-2.ruangguru.com/landing-pages/assets/51eec2d1-9310-4d8e-a530-aaa20c256b81.jpeg?convert=webp",school:"SDN Cipinang Muara 19 Pagi (V)",program:"Scratch",thumbnail:"https://cdn-web-2.ruangguru.com/landing-pages/assets/05cb44d6-1fdc-4046-b530-83f2140722db.png?convert=webp",description:"<p>Dalam permainan ini, pemain menggerakkan karakter utama untuk melewati maze (labirin) yang sudah dirancang. Di sepanjang jalan, pemain akan bertemu dengan karakter lain yang membutuhkan bantuan untuk mengatasi masalah kesehatan mereka — seperti lupa minum obat, tidak punya makanan sehat, dll. Permainan ini mengajarkan pentingnya menjaga kesehatan diri dan peduli terhadap orang lain.</p>\n<br/>\n<p>Konsep yang digunakan:</p>\n<p><b>Keyboard Controlled</b>: Pemain menggerakkan karakter dengan tombol panah di keyboard.</p>\n<p><b>Operators</b>: Digunakan untuk mengecek kondisi tertentu, misalnya ketika karakter menyentuh dinding atau orang lain.</p>\n<p><b>My Blocks</b>: Digunakan untuk membuat perintah khusus, seperti memberi bantuan atau memunculkan kode skrip yang sudah disusun sebelumnya</p>",howToPlay:"<p>1. Gunakan tombol panah di keyboard untuk menggerakkan karakter.</p>\n<p>2. Jelajahi maze dan cari karakter lain yang butuh bantuan.</p>\n<p>3. Jika bertemu karakter, bantu mereka dengan mengikuti petunjuk yang muncul.</p>\n<p>4. Hati-hati jangan menabrak dinding maze!</p>\n<p>5. Selesaikan semua misi bantuan untuk memenangkan permainan.</p>\n",link:"https://scratch.mit.edu/projects/1202670817/"},{title:"Sensing Game",studentName:"Navis Sahl Putera",studentPhoto:"https://cdn-web-2.ruangguru.com/landing-pages/assets/399ebb6e-d9ae-4506-9f45-5530cef9f536.jpeg?convert=webp",school:"xxx",program:"Scratch",thumbnail:"https://cdn-web-2.ruangguru.com/landing-pages/assets/3ba25233-40fd-4ee2-8c03-4d2082b3471e.png?convert=webp",description:"<p>Game balapan lari yang dibuat di Scratch, tapi uniknya: tidak pakai keyboard atau mouse! Game ini menggunakan kamera webcam untuk mendeteksi gerakan pemain. Tujuannya adalah sampai ke garis finish paling cepat.</p>\n<br/>\n<p>Konsep yang digunakan:</p>\n<p>Sensing: Mendeteksi gerakan dari kamera dan memicu aksi dalam game.</p>\n<p>Events: Saat gerakan terdeteksi, akan muncul event (seperti broadcast) agar karakter mulai bergerak.</p>\n<p>Variables:Variabel untuk menghitung waktu tempuh masing-masing pelari.</p>\n<p>Control: Blok kontrol seperti if, repeat, dan broadcast untuk mengatur alur permainan.</p>",howToPlay:"<p>Kamu cukup bergerak di depan kamera (misalnya lambaikan tangan atau gerakkan badan), dan karakter kamu akan mulai berlari.</p>\n\n<p>Game ini bisa dimainkan oleh 3 pemain sekaligus. Pemain cukup berdiri di depan Player ara (pastikan tubuh menyentuhnya).</p>\n<p>Klik Green Flag, lalu bergeraklah di depan kamera (melambaikan tangan, menggerakkan badan, dll).\nKarakter akan mulai berlari.</p>",link:"https://scratch.mit.edu/projects/552511411/"}];function C(){$("#project-detail").hide(),$("body").css("overflow","auto")}$(document).on("click",".btn-show-detail",(function(){!function(a){const n=j[a];let e=`\n      <div class="page-center rounded-xl relative bg-white p-3-cus md:p-8" style="max-width: 60rem; max-height: 90vh;">\n        <div class="btn-close-detail absolute -top-5 -right-5 bg-white text-2xl font-bold rounded-full w-10 h-10 flex items-center justify-center cursor-pointer ring-2 ring-gray-300">X</div>\n        <div class="grid md:grid-cols-2 gap-5 overflow-y-auto" style="max-height: calc(90vh - 4rem);">\n          <div class="flex flex-col gap-3">\n            <img class="w-full h-40 md:h-60 object-cover rounded-xl" src="${n.thumbnail}" alt="" loading="lazy">\n            <h2 class="text-xl md:text-2xl lg:text-3xl font-bold">${n.title}</h2>\n            <span class="inline-block text-white px-3-cus py-1-cus rounded-full text-sm w-max" style="background-color: #265E9B;">${n.program}</span>\n\n            <p class="text-sm md:text-base text-gray-500 mb-0">Oleh : ${n.studentName}</p>\n            <p class="text-xs md:text-sm text-gray-400 mb-0">${n.school}</p>\n          </div>\n          <div class="flex flex-col gap-3 h-full">\n            \n            <div class="overflow-y-auto flex-1 pr-2" style="max-height: calc(90vh - 16rem);">\n              <h4 class="text-base md:text-lg font-bold mb-2" style="color: #265E9B;">📝 Deskripsi Project</h4>\n              <div class="text-sm md:text-base text-gray-700 mb-4">${n.description}</div>\n              \n              <h4 class="text-base md:text-lg font-bold mb-2" style="color: #265E9B;">🎮 Cara Memainkan</h4>\n              <div class="text-sm md:text-base text-gray-700">${n.howToPlay}</div>\n            </div>\n            \n            <a href="${n.link}" target="_blank" class="mt-auto">\n              <button class="w-full text-center text-sm md:text-base bg-F78232 text-white rounded-full px-5-cus py-3-cus font-semibold">Mainkan Project</button>\n            </a>\n          </div>\n        </div>\n      </div>\n  `;$("#project-detail").html(e),$("#project-detail").show(),$("body").css("overflow","hidden"),$(document).on("click",".btn-close-detail",(function(){C()})),$("#project-detail").off("click").on("click",(function(a){"project-detail"===a.target.id&&C()}))}($(this).data("index"))}));const T=[{name:"ScratchJr",yo:"5-6 Tahun",desc:"Bahasa Pemrograman Blok-Ikon <br> 6 Level x 12 Jam Pertemuan",icon:"https://cdn-web-2.ruangguru.com/landing-pages/assets/470bd55f-ae4e-4007-91d1-0a85d45045cf.png",poin:["Level 1 : Story Animation","Level 2 : Interactive Projects","Level 3 : Simple Mechanism Games","Level 4 : Complex Mechanism Games","Level 5 : Game Design Pt 1","Level 6 : Game Design Pt 2"]},{name:"Scratch",yo:"7-12 Tahun",desc:"Bahasa Pemrograman Visual <br> 6 Level x 12 Jam Pertemuan",icon:"https://cdn-web-2.ruangguru.com/landing-pages/assets/0f262f67-4641-4bec-8ff3-11e93cd4b88c.png",poin:["Level 1 : Interactive Story Projects","Level 2 : Keyboard-Controlled Games","Level 3 : Complex Movement Projects","Level 4 : Mouse-Controlled Simulations","Level 5 : Advanced Controller Projects","Level 6 : Advanced Game Design"]},{name:"Roblox Studio",yo:"10-15 Tahun",desc:"Bahasa Pemrograman Teks <br> 6 Level x 12 Jam Pertemuan",icon:"https://cdn-web-2.ruangguru.com/landing-pages/assets/d6c27e49-6688-4da3-a584-8d5194dab7ff.png?convert=webp",poin:["Level 1 : Interactive Story Projects","Level 2 : Keyboard-Controlled Games","Level 3 : Complex Movement Projects","Level 4 : Mouse-Controlled Simulations","Level 5 : Advanced Controller Projects","Level 6 : Advanced Game Design"]},{name:"Python",yo:"13-17 Tahun",desc:"Bahasa Pemrograman Teks <br> 6 Level x 12 Jam Pertemuan",icon:"https://cdn-web-2.ruangguru.com//landing-pages/assets/6d61033d-4122-4e11-8375-147a1ff97f28.png",poin:["Level 1 : Python Fundamental","Level 2 : Data Handling","Level 3 : GUI [Tkinter]","Level 4 : OOP Foundations","Level 5 : Python Platformer","Level 6 : Python Web + AI"]}];
